# Supabase PostgreSQL Configuration
# 1. Create project at https://supabase.com
# 2. Go to Settings → Database → Copy Connection URI
# 3. Replace the value below with your connection string

# PostgreSQL configuration
DATABASE_BACKEND=postgresql
DATABASE_URL=postgresql://postgres.your-project.supabase.co:6543/postgres?sslmode=require

# Supabase connection (format: postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:6543/postgres)
# Replace 'your-project' and 'password' with your actual values