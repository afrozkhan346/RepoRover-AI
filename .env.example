# ===========================================
# RepoRover AI - Environment Configuration
# ===========================================
# AI-powered learning platform for developers
# Copy this file to .env.development or .env.production
# ===========================================

#  APPLICATION SETTINGS
# ===========================================
NODE_ENV=development
APPLICATION_NAME=RepoRover-AI
APPLICATION_VERSION=1.0.0
LOG_LEVEL=debug
DEBUG_MODE=true

# ===========================================
#  API GATEWAY CONFIGURATION
# ===========================================
API_GATEWAY_PORT=8080
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_URL=http://localhost:8080

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-for-security
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=repoorover-ai
JWT_AUDIENCE=repoorover-users

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=true

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Correlation-ID

# ===========================================
#  GEMINI AI CONFIGURATION
# ===========================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.7

# ===========================================
#  DATABASE CONFIGURATION
# ===========================================
# Turso SQLite (Primary Database for Next.js App)
# Get credentials at: https://turso.tech
TURSO_CONNECTION_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Alternative: Local SQLite for development
# TURSO_CONNECTION_URL=file:local.db

# ===========================================
#  REDIS CACHE (Optional - for performance optimization)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TLS=false

# ===========================================
#  AUTHENTICATION (Better Auth)
# ===========================================
BETTER_AUTH_SECRET=your-better-auth-secret-minimum-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Session Configuration
SESSION_SECRET=your-session-secret-key-minimum-32-characters-long
SESSION_MAX_AGE=2592000
SESSION_SECURE=false

# ===========================================
#  OAUTH PROVIDERS
# ===========================================
# Google OAuth
# Setup at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# Setup at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ===========================================
#  GITHUB API
# ===========================================
# Personal Access Token for GitHub API
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_API_URL=https://api.github.com

# ===========================================
#  FRONTEND CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ===========================================
#  ANALYTICS (Optional)
# ===========================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
#  EMAIL CONFIGURATION (Optional)
# ===========================================
# For authentication emails (password reset, verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@repoorover.ai

# ===========================================
#  MONITORING & LOGGING (Optional)
# ===========================================
# Sentry for error tracking
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development

# ===========================================
#  DEPLOYMENT CONFIGURATION
# ===========================================
# Application URL (production)
APP_URL=https://your-app-domain.com

# ===========================================
#  FEATURE FLAGS
# ===========================================
ENABLE_ANALYTICS=false
ENABLE_ERROR_REPORTING=false
ENABLE_REDIS_CACHE=false
ENABLE_EMAIL_VERIFICATION=false
ENABLE_RATE_LIMITING=true

# ===========================================
#  DEVELOPMENT TOOLS
# ===========================================
# Database Studio (Drizzle Studio)
DRIZZLE_STUDIO_PORT=4983

# ===========================================
#  NOTES
# ===========================================
# - Never commit .env.development or .env.production files
# - Keep this .env.example file updated as template
# - Use strong, random secrets for all secret keys
# - Minimum 32 characters for JWT_SECRET and SESSION_SECRET
# - Rotate credentials regularly in production
# - Use environment-specific files (.env.development, .env.production)
